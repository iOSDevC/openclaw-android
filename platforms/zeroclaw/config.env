# config.env — ZeroClaw platform metadata and dependency declarations
# Sourced by orchestrators via load_platform_config()

# ── Platform info ──
PLATFORM_NAME="ZeroClaw"
PLATFORM_BINARY="zeroclaw"
PLATFORM_DATA_DIR="$HOME/.zeroclaw"
PLATFORM_VERSION_CMD="zeroclaw --version"
PLATFORM_START_CMD="zeroclaw serve"
PLATFORM_POST_INSTALL_MSG="Run 'zeroclaw init' to start setup."

# ── Dependency declarations ── orchestrator reads these for conditional install
PLATFORM_NEEDS_GLIBC=false
PLATFORM_NEEDS_NODEJS=false
PLATFORM_NEEDS_BUILD_TOOLS=false
PLATFORM_NEEDS_PYTHON=false
PLATFORM_NEEDS_PROOT=false

# ── Install method ──
PLATFORM_INSTALL_METHOD="github"
PLATFORM_NPM_PACKAGE=""
PLATFORM_GITHUB_REPO="AidanPark/zeroclaw"
PLATFORM_PIP_PACKAGE=""
